# =============================================================================
# TeamFlow EPMS — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Django
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py
media/uploads/

# Celery
celerybeat-schedule
celerybeat.pid

# Coverage / Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Type checking
.mypy_cache/
.pytype/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
.vercel
*.tsbuildinfo
next-env.d.ts

# pnpm
.pnpm-store/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
