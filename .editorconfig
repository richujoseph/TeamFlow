# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across all editors and IDEs.

root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python files — 4-space indent (PEP 8)
[*.py]
indent_size = 4
max_line_length = 88

# TypeScript / JavaScript / JSX / TSX — 2-space indent
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# JSON / YAML / TOML — 2-space indent
[*.{json,yml,yaml,toml}]
indent_size = 2

# Markdown — preserve trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false

# Dockerfiles
[Dockerfile*]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 4

# CSS / SCSS
[*.{css,scss}]
indent_size = 2

# HTML
[*.html]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
