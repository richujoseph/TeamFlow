# =============================================================================
# TeamFlow EPMS — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=teamflow
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=teamflow_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Composed DATABASE_URL (used by some tools, not Django directly)
DATABASE_URL=postgresql://teamflow:teamflow_dev_password@postgres:5432/teamflow

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# JWT Cookie Settings
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-different-random-secret
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_SECURE=false
JWT_COOKIE_HTTPONLY=true
JWT_COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Frontend (Next.js public variables must start with NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=TeamFlow

# -----------------------------------------------------------------------------
# Email (development uses console backend by default)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# -----------------------------------------------------------------------------
# Sentry (production only)
# -----------------------------------------------------------------------------
SENTRY_DSN=
